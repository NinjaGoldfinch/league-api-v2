APP_NAME=League API
APP_ENV=development
EXPERIMENTAL_FRONTEND_ENABLED=false
RIOT_API_KEY=
OPERATOR_API_TOKEN=
OPERATOR_MUTATION_REQUESTS=30
OPERATOR_MUTATION_WINDOW_SECONDS=60
DEFAULT_PLATFORM_ROUTE=oc1
DEFAULT_REGIONAL_ROUTE=sea
RIOT_APP_RATE_LIMIT_SHORT_REQUESTS=20
RIOT_APP_RATE_LIMIT_SHORT_WINDOW_SECONDS=1
RIOT_APP_RATE_LIMIT_LONG_REQUESTS=100
RIOT_APP_RATE_LIMIT_LONG_WINDOW_SECONDS=120
RIOT_RATE_LIMIT_MAX_RETRIES=3
RIOT_RATE_LIMIT_RETRY_AFTER_BUFFER_SECONDS=1
RIOT_RATE_LIMIT_RETRY_AFTER_FALLBACK_SECONDS=120
RIOT_MANUAL_RATE_LIMIT_RESERVE_FRACTION=0.2
RIOT_MANUAL_RATE_LIMIT_UNLOCK_SECONDS=10
RIOT_REQUEST_LOGS_ENABLED=true
CORS_ALLOWED_ORIGINS=[]

DATABASE_URL=postgresql+asyncpg://league_api:league_api@localhost:5432/league_api
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=300
CACHE_STALE_WHILE_REVALIDATE_SECONDS=300
CACHE_MATCH_DETAIL_TTL_SECONDS=86400
CACHE_MATCH_IDS_TTL_SECONDS=300
CACHE_ACCOUNT_TTL_SECONDS=3600
CACHE_SUMMONER_TTL_SECONDS=3600
CACHE_LEAGUE_ENTRIES_TTL_SECONDS=300
CACHE_LADDER_TTL_SECONDS=300
